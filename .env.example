# Backend environment variables (set these in the Render dashboard for production).
#
# Note: this project doesn't use the "dotenv" package, so this file is NOT
# auto-loaded locally — it's documentation of what Render needs. Locally,
# server.js falls back to 127.0.0.1 Mongo and port 5000 automatically when
# these aren't set, so you don't need this file for local development.

# MongoDB Atlas connection string (see Step 4 below for the exact format)
MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/jobportal?retryWrites=true&w=majority

# Exact Vercel frontend URL, so CORS only accepts requests from your deployed site
CORS_ORIGIN=https://your-nexthire-frontend.vercel.app
